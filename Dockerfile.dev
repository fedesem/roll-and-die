FROM node:22.13.1-bookworm-slim

WORKDIR /app

ENV CI=true
ENV CHOKIDAR_USEPOLLING=true
ENV npm_config_build_from_source=true

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

EXPOSE 4000 5174

CMD ["sh", "-lc", "npm ci && npx concurrently -k -n server,client -c blue,magenta \"npm run dev --workspace server\" \"npm run dev --workspace client -- --host 0.0.0.0\""]
