FROM node:24.14.0-alpine

WORKDIR /app

ENV CI=true
ENV CHOKIDAR_USEPOLLING=true

RUN apk add --no-cache python3 make g++

EXPOSE 4000 5174

CMD ["sh", "-lc", "if [ ! -x ./node_modules/.bin/concurrently ]; then echo \"dependencies missing; run ./app.sh npm install\" >&2; exit 1; fi; exec ./node_modules/.bin/concurrently -k -n server,client -c blue,magenta \"npm run dev --workspace server\" \"npm run dev --workspace client -- --host 0.0.0.0\""]
